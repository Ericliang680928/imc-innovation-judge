# ════════════════════════════════════════════════
# IMC 評審系統 — 環境變數範例
# ════════════════════════════════════════════════
# 把這個檔案複製為 .env(去掉 .example),填入你需要用的 API Key
# 五個只要填一個即可,系統會依 Sidebar 選擇對應的 Key

# ─────────────────────────────────────────────
# 🚀 Groq API Key (推薦!免費 + 最快)
# 申請:https://console.groq.com/keys
# 額度:每分鐘 30 次免費,速度最快
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 🌍 OpenRouter API Key (推薦!免費模型聚合)
# 申請:https://openrouter.ai/keys
# 額度::free 後綴模型完全免費 (DeepSeek / Llama / Qwen 等)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 🇫🇷 Mistral AI API Key (免費)
# 申請:https://console.mistral.ai/api-keys
# 額度:La Plateforme 免費層,每月限額
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 🤖 Google Gemini API Key (免費)
# 申請:https://aistudio.google.com/app/apikey
# 額度:每天 1500 次免費(Flash 系列)
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─────────────────────────────────────────────
# 💎 Anthropic Claude API Key (付費,品質頂尖)
# 申請:https://console.anthropic.com/settings/keys
# 額度:新帳號送 $5 試用
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
